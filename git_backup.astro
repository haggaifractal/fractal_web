---
import ContactSection from '../components/ContactSection.astro';
import Layout from '../layouts/Layout.astro';
import NetworkBackground from '../components/NetworkBackground.astro';
---
<Layout title="Home">
    <div class="relative w-full overflow-hidden">
        <NetworkBackground />
        <!-- Hero Section -->
        <section class="relative z-10 max-w-6xl mx-auto px-8 py-12 md:py-20 flex flex-col md:flex-row items-center gap-16 mt-8">
        <div class="flex-1 flex flex-col gap-6">
            <div class="animate-fade-up inline-block px-4 py-1.5 rounded-full bg-primary-container text-on-primary-container font-semibold text-sm w-fit border border-primary/10 shadow-sm font-headline" style="--delay: 100ms">
                20+ Years of Technology Expertise
            </div>
            <h1 class="animate-fade-up text-5xl md:text-7xl font-bold font-headline leading-tight text-on-surface tracking-tight mt-4" style="--delay: 300ms">
                Technology <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-fixed via-primary-fixed-dim to-emerald-600">Business-Wise</span>
            </h1>
            <p class="animate-fade-up text-on-surface-variant text-lg md:text-2xl font-light leading-relaxed max-w-xl" style="--delay: 500ms">
                Fractal specializes in providing IT consulting and support solutions to business and industrial customers who expect excellence.
            </p>
            <div class="animate-fade-up flex flex-col sm:flex-row w-full sm:w-auto gap-4 mt-6" style="--delay: 700ms">
                <a href="/about" class="px-8 py-3.5 bg-primary text-white font-bold rounded-full hover:bg-surface-tint transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 active:scale-95">Discover More</a>
                <a href="/services" class="px-8 py-3.5 bg-white text-primary font-bold rounded-full border-2 border-primary/20 hover:border-primary hover:bg-primary/5 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 active:scale-95">Our Services</a>
            </div>
        </div>
        
        <div class="flex-1 relative w-full">
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-tertiary/20 blur-3xl opacity-50 rounded-[4rem]"></div>
            <div class="animate-fade-up relative w-full bg-surface-container-lowest border border-outline-variant/30 rounded-[2.5rem] shadow-2xl overflow-hidden aspect-square group mt-10 md:mt-0" style="--delay: 900ms">
                 <img src="/hero_server_room_1774520634037.png" alt="Fractal IT Infrastructure" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 block" />
                 <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/60 via-transparent to-transparent opacity-80 pointer-events-none"></div>
            </div>
        </div>
        </section>
    </div>

    <!-- Motto / Value Proposition Area -->
    <section class="reveal-on-scroll bg-surface-container-low border-y border-surface-container mt-20 py-24 px-8">
        <div class="max-w-4xl mx-auto text-center md:text-left">
            <h2 class="text-3xl md:text-5xl font-bold text-primary mb-8 font-headline">What Is Our Motto?</h2>
            <p class="text-xl md:text-3xl text-on-surface leading-snug font-light">
                Fractal's motto is a <strong class="text-primary font-bold">comprehensive customer service concept</strong> that includes defining its needs and their implementation in hardware, software, and system support alongside the core business.
            </p>
        </div>
    </section>

    <!-- Contact Us Section -->
    <ContactSection lang="en" />

</Layout>
