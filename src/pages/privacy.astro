---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy">
    <div class="max-w-4xl mx-auto px-8 py-32 text-on-surface">
        <h1 class="text-4xl md:text-5xl font-bold font-headline mb-8 text-primary">Privacy Policy</h1>
        <div class="prose prose-invert max-w-none text-on-surface-variant">
            <p>Effective Date: 2024</p>
            <p>Your privacy is important to Fractal Computers. This policy outlines how we collect, use, and protect your information when you interact with our services and this website.</p>
            <h2 class="text-2xl font-bold mt-8 mb-4 text-on-surface">Data Collection</h2>
            <p>We only collect data voluntarily provided via our secure forms, including Name, Email, and Phone data necessary to service your technical requests.</p>
            <h2 class="text-2xl font-bold mt-8 mb-4 text-on-surface">Data Protection</h2>
            <p>All transmitted data is encrypted. We do not sell your personal data to third parties.</p>
        </div>
    </div>
</Layout>
