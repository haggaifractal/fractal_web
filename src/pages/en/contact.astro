---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Contact Us">
    <section class="animate-fade-up max-w-4xl mx-auto px-8 py-24 text-center mt-12 bg-surface" style="--delay: 100ms">
        <h1 class="text-5xl font-bold font-headline mb-4 text-primary">Contact Us</h1>
        <div class="h-1 w-20 bg-primary mx-auto rounded-full mb-8"></div>
        <p class="text-on-surface-variant text-lg mb-12">Submit a ticket for neural support or reach out to our enterprise sales team. We reply inside of 15 minutes.</p>
        
        <!-- Elegant Standard Form -->
        <form class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left bg-surface-container-lowest p-12 rounded-[2rem] shadow-[0_20px_40px_rgba(0,104,87,0.06)] border border-surface-container">
            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-primary tracking-wide uppercase" for="name">Name</label>
                <input type="text" id="name" class="border border-outline-variant/40 p-3 rounded-xl bg-surface focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all" placeholder="Enter your name" />
            </div>
            
            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-primary tracking-wide uppercase" for="email">Email</label>
                <input type="email" id="email" class="border border-outline-variant/40 p-3 rounded-xl bg-surface focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all" placeholder="Enter your email" />
            </div>
            
            <div class="flex flex-col gap-2 md:col-span-2">
                <label class="text-sm font-bold text-primary tracking-wide uppercase" for="message">Message</label>
                <textarea id="message" rows="5" class="border border-outline-variant/40 p-3 rounded-xl bg-surface focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all resize-none" placeholder="Provide details about your IT request..."></textarea>
            </div>
            
            <div class="md:col-span-2 flex justify-end">
                <button type="button" class="px-10 py-4 bg-primary text-white font-bold rounded-full hover:bg-surface-tint transition-all shadow-xl shadow-primary/20 hover:scale-105 active:scale-95">Send Support Request</button>
            </div>
        </form>
    </section>
</Layout>
