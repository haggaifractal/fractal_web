---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Message Sent Successfully">
    <section class="animate-in max-w-3xl mx-auto px-8 py-32 text-center mt-12 bg-surface flex flex-col items-center justify-center min-h-[50vh]">
        <div class="w-24 h-24 bg-primary-container rounded-full flex items-center justify-center mb-8 shadow-inner border border-primary/20">
            <span class="material-symbols-outlined text-6xl text-primary drop-shadow-sm">check_circle</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl font-bold font-headline mb-6 text-on-surface tracking-tight">
            Thank You for Reaching Out!
        </h1>
        
        <p class="text-xl leading-relaxed text-on-surface-variant font-medium mb-10 max-w-xl text-center">
            Your message has been successfully delivered.<br/>
            The <strong class="text-primary">Fractal</strong> team has received your inquiry and will get back to you shortly.
        </p>
        
        <a href="/en/" class="mt-10 px-12 py-4 bg-primary text-white rounded-full font-bold shadow-lg shadow-primary/20 hover:bg-surface-tint hover:scale-105 active:scale-95 transition-all text-lg flex items-center justify-center gap-3">
            <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            Back to Home
        </a>
    </section>
</Layout>
