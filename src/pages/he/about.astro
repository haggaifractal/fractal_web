---
import ContactSection from '../../components/ContactSection.astro';
import LayoutHe from '../../layouts/LayoutHe.astro';

const timeline = [
    { year: '2002', title: 'הקמת פרקטל', desc: 'התחלנו את המסע כחברת סיסטם וייעוץ ממוקדת.' },
    { year: '2010', title: 'התרחבות', desc: 'הקמנו מאות רשתות מעשיות עבור גופים מוסדיים.' },
    { year: '2018', title: 'שותפויות ענק', desc: 'ספקי IT רשמיים לארגוני ענק ומערכות רפואה.' },
    { year: 'כיום', title: 'פסגת הטכנולוגיה', desc: 'שירות ואמינות ללא פשרות לחברות המורכבות ביותר.' }
];

const testimonials = [
    { quote: "לחברת פרקטל: תודה רבה על התמיכה והשירות המקצועי, האמין והמסור שהענקתם לנו לאורך הדרך. אנו ממליצים בחום לכל חברה לעבוד איתכם, תרגישו חופשי להשתמש בנו כממליצים רשמיים.", author: "מוקד אמון", role: "לקוח אבטחה" },
    { quote: "צוות פרקטל היקר, תודה מקרב לב על התמיכה הרציפה והטיפול המקצועי שאתם מספקים לנו באמינות ובמסירות. אנחנו ממליצים בחום, ספק אסטרטגי מהמעלה הראשונה.", author: "T&M Protection Resources", role: "" },
    { quote: "זכינו לשירות ללא דופי, מהיר וממוקד מחברת IT שבאמת מבינה עסקית, גם מעבר לטכנולוגיה.", author: "ל.כ. בע\"מ", role: "" }
];
---

<LayoutHe title="אודותינו">
    <section class="animate-fade-up max-w-4xl mx-auto px-8 py-20 text-center mt-12 bg-surface" style="--delay: 100ms">
        <h1 class="text-5xl md:text-7xl font-bold font-headline mb-8 text-primary tracking-tight">קצת עלינו</h1>
        <p class="text-xl leading-relaxed text-on-surface-variant font-light mb-8 text-right bg-surface-container-lowest p-8 rounded-3xl shadow-sm border border-outline-variant/20 relative dir-rtl">
            <span class="absolute -top-4 -right-4 material-symbols-outlined text-4xl text-primary/20">format_quote</span>
            חברת <strong class="text-primary font-bold">פרקטל</strong> מתמחה במתן פתרונות מחשוב מקיפים ושירותי IT תומכים ללקוחות עסקיים ותעשייתיים שפועלים בקצבים גבוהים.
            <br/><br/>
            אנו בונים ומתחזקים מערכות ייעודיות המותאמות לדרישות ולזרימת העבודה הייחודית של כל לקוח. תחומי הפעילות שלנו כוללים מגוון עמוק של שירותים:<br/>
            הקמה ותחזוקה שוטפת של רשתות מחשבים, פתרונות אבטחת מידע, תחזוקת תוכנות בסביבת שרת מאובטחת, טיפול בתוכנות שרטוט ותכנון (כדוגמת Auto CAD), ושירות צמוד למערכות תוכנה של מוקדי ביטחון ואבטחה.
            <br/><br/>
            עם למעלה מ- <strong class="text-primary font-bold text-2xl">20 שנות ניסיון</strong> בהקמת מאות סוגים שונים של רשתות מחשבים אצל חברות ענק מוסדיות, הסטנדרט המקצועי הבלתי-מתפשר שלנו – יחד עם אחיזת ידע עמוקה בטכנולוגיות התקשורת החדישות ביותר ויחס אישי – מבטיחים התקנה יציבה, שירות אמין והתאמה מושלמת של המערכת לצרכי העסק שלך.
        </p>
    </section>

    <!-- Timeline Section -->
    <section class="reveal-on-scroll max-w-6xl mx-auto px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 dir-rtl">
            {timeline.map((step) => (
                <div class="flex flex-col items-center text-center p-6 bg-white rounded-2xl border border-surface-container-highest shadow-sm hover:-translate-y-1 transition-transform">
                    <span class="text-4xl font-headline font-black text-primary border-b-4 border-primary/20 pb-2 mb-4">{step.year}</span>
                    <h3 class="font-bold text-lg mb-2 text-on-surface">{step.title}</h3>
                    <p class="text-sm text-on-surface-variant font-medium">{step.desc}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- Testimonials Section -->
    <section class="reveal-on-scroll bg-surface-container-low border-y border-surface-container py-24 px-8 mt-12 mb-0">
        <div class="max-w-6xl mx-auto dir-rtl">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold font-headline text-on-surface mb-4">לקוחותינו ממליצים</h2>
                <p class="text-xl text-on-surface-variant font-light">מה אומרות החברות והתאגידים המובילים בישראל, שעובדים איתנו כבר עשרות שנים.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {testimonials.map((test) => (
                    <div class="flex flex-col p-8 bg-surface-container-lowest rounded-[2rem] shadow-sm border border-outline-variant/30 hover:shadow-lg transition-shadow relative">
                        <span class="material-symbols-outlined text-primary-fixed opacity-30 text-5xl absolute top-6 right-6">format_quote</span>
                        <p class="text-on-surface-variant text-lg font-medium leading-relaxed my-8 relative z-10 flex-grow text-right pr-6">
                            "{test.quote}"
                        </p>
                        <div class="flex items-center gap-4 mt-auto border-t border-outline-variant/20 pt-6">
                            <div class="w-12 h-12 bg-primary-container rounded-full flex items-center justify-center text-on-primary-container font-headline font-bold text-xl">
                                {test.author.charAt(0)}
                            </div>
                            <div class="flex flex-col text-right">
                                <span class="font-bold text-on-surface">{test.author}</span>
                                {test.role && <span class="text-sm text-on-surface-variant font-medium">{test.role}</span>}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Exact Contact Us Section from user specification -->
    <ContactSection lang="he" />

</LayoutHe>
