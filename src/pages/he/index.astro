---
import ContactSection from '../../components/ContactSection.astro';
import LayoutHe from '../../layouts/LayoutHe.astro';
import NetworkBackground from '../../components/NetworkBackground.astro';
---

<LayoutHe title="ראשי">
    <div class="relative w-full overflow-hidden">
        <NetworkBackground />
        <!-- Hero Section -->
        <section class="relative z-10 max-w-6xl mx-auto px-8 py-12 md:py-20 flex flex-col md:flex-row items-center gap-16 mt-8">
            <div class="flex-1 flex flex-col gap-6 text-right">
                <div class="animate-fade-up inline-block px-5 py-1.5 rounded-full bg-primary-container text-on-primary-container font-semibold text-sm w-fit border border-primary/10 shadow-sm font-headline" style="--delay: 100ms">
                    20+ שנות מומחיות טכנולוגית
                </div>
                <h1 class="animate-fade-up text-4xl md:text-7xl font-bold font-headline leading-tight text-on-surface tracking-tight mt-4" style="--delay: 300ms">
                    טכנולוגיה חכמה לעסקים
                </h1>
                <p class="animate-fade-up text-on-surface-variant text-lg md:text-2xl font-light leading-relaxed max-w-xl" style="--delay: 500ms">
                    פרקטל מתמחה במתן פתרונות מחשוב מלאים, שירות ותמיכה טכנית מתקדמת ללקוחות עסקיים ותעשייתיים השואפים למצוינות.
                </p>
                <div class="animate-fade-up flex flex-col sm:flex-row w-full sm:w-auto gap-4 mt-6" style="--delay: 700ms">
                    <a href="/he/about" class="px-8 py-3.5 bg-primary text-white font-bold rounded-full hover:bg-surface-tint transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 active:scale-95">למידע נוסף אודותינו</a>
                    <a href="/he/services" class="px-8 py-3.5 bg-white text-primary font-bold rounded-full border-2 border-primary/20 hover:border-primary hover:bg-primary/5 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 active:scale-95">צפה בשירותים</a>
                </div>
            </div>
            
            <div class="flex-1 relative w-full">
                <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-tertiary/20 blur-3xl opacity-50 rounded-[4rem]"></div>
                <div class="animate-fade-up relative w-full bg-surface-container-lowest border border-outline-variant/30 rounded-[2.5rem] shadow-2xl overflow-hidden aspect-square group mt-10 md:mt-0" style="--delay: 900ms">
                     <img src="/hero_server_room_1774520634037.png" alt="Fractal IT Infrastructure" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 block" />
                     <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/60 via-transparent to-transparent opacity-80 pointer-events-none"></div>
                </div>
            </div>
        </section>
    </div>

    <!-- Motto / Value Proposition Area -->
    <section class="reveal-on-scroll bg-surface-container-low border-y border-surface-container mt-20 py-24 px-8">
        <div class="max-w-4xl mx-auto text-center md:text-right">
            <h2 class="text-3xl md:text-5xl font-bold text-primary mb-8 font-headline">המוטו שלנו</h2>
            <p class="text-xl md:text-3xl text-on-surface leading-snug font-light">
                המוטו של פרקטל הוא <strong class="text-primary font-bold">תפיסת שירות כוללת (מקיפה)</strong> המורכבת מאפיון והגדרת הצרכים, דרך יישומם הטכנולוגי (חומרה, תוכנה) ועד לתחזוקה שוטפת במקביל לפעילות ליבת העסק.
            </p>
        </div>
    </section>

    <ContactSection lang="he" />

</LayoutHe>
