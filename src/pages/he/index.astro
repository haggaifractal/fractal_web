---
import ContactSection from '../../components/ContactSection.astro';
import LayoutHe from '../../layouts/LayoutHe.astro';
import NetworkBackground from '../../components/NetworkBackground.astro';
---

<LayoutHe title="ראשי">
    <div class="relative w-full overflow-hidden">
        <NetworkBackground />
        <!-- Hero Section -->
        <section class="relative z-10 max-w-6xl mx-auto px-8 py-12 md:py-20 flex flex-col md:flex-row items-center gap-16 mt-8">
            <div class="flex-1 flex flex-col gap-6 text-right">
                <div class="inline-block px-5 py-1.5 rounded-full bg-primary-container text-on-primary-container font-semibold text-sm w-fit border border-primary/10 shadow-sm font-headline">
                    20+ שנות מומחיות טכנולוגית
                </div>
                <h1 class="text-4xl md:text-7xl font-bold font-headline leading-tight text-on-surface tracking-tight mt-4">
                    טכנולוגיה חכמה לעסקים
                </h1>
                <p class="text-on-surface-variant text-lg md:text-2xl font-light leading-relaxed max-w-xl">
                    פרקטל מתמחה במתן פתרונות מחשוב מלאים, שירות ותמיכה טכנית מתקדמת ללקוחות עסקיים ותעשייתיים השואפים למצוינות.
                </p>
                <div class="flex flex-col sm:flex-row w-full sm:w-auto gap-4 mt-6">
                    <a href="#contact" class="w-full sm:w-auto text-center px-8 py-4 bg-primary text-on-primary rounded-xl font-bold hover:shadow-lg hover:shadow-primary/30 hover:scale-105 active:scale-95 transition-all text-lg">צור קשר לתכנון</a>
                    <a href="/he/services" class="w-full sm:w-auto text-center px-8 py-4 border-2 border-outline/30 text-on-surface rounded-xl font-bold hover:border-primary hover:text-primary hover:bg-surface-container transition-all text-lg">סל השירותים שלנו</a>
                </div>
            </div>
            
            <div class="flex-1 relative w-full">
                <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-tertiary/20 blur-3xl opacity-50 rounded-[4rem]"></div>
                <div class="relative w-full bg-surface-container-lowest border border-outline-variant/30 rounded-[2.5rem] shadow-2xl overflow-hidden aspect-square group mt-10 md:mt-0">
                     <img src="/hero_server_room_1774520634037.png" alt="Fractal IT Infrastructure" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 block" />
                     <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/60 via-transparent to-transparent opacity-80 pointer-events-none"></div>
                </div>
            </div>
        </section>
    </div>

    <!-- Motto / Value Proposition Area -->
    <section class="bg-surface-container-low border-y border-surface-container mt-20 py-24 px-8">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-3xl md:text-5xl font-bold text-primary mb-8 font-headline">המוטו שלנו</h2>
            <p class="text-xl md:text-3xl text-on-surface leading-snug font-light">
                המוטו של פרקטל הוא <strong class="text-primary font-bold">תפיסת שירות כוללת (מקיפה)</strong> המורכבת מאפיון והגדרת הצרכים, דרך יישומם הטכנולוגי (חומרה, תוכנה) ועד לתחזוקה שוטפת במקביל לפעילות ליבת העסק.
            </p>
        </div>
    </section>

    <ContactSection lang="he" />

</LayoutHe>
