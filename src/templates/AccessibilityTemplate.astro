---
import Layout from '../layouts/Layout.astro';
import ContactSection from '../components/ContactSection.astro';

export interface Props {
    lang?: 'en' | 'he';
}

const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';
---

<Layout title={isHe ? "הצהרת נגישות" : "Accessibility Statement"} lang={lang}>
    <div class={`max-w-4xl mx-auto px-8 py-32 text-on-surface ${isHe ? 'text-right' : 'text-left'}`}>
        <h1 class="text-4xl md:text-5xl font-bold font-headline mb-8 text-primary">
            {isHe ? "הצהרת נגישות" : "Accessibility Statement"}
        </h1>
        
        {isHe ? (
            <div class="prose prose-invert max-w-none text-on-surface-variant text-right" dir="rtl">
                <p>חברת פרקטל מחשבים ותקשורת רואה בנגישות ערך ליבה עסקי וחברתי. פלטפורמה זו נבנתה ועוצבה על מנת לעמוד בתקן WCAG 2.1 ברמת AA, כך שמשתמשים עם מוגבלויות יוכלו לנווט, להבין ולהשתמש בכל מערכות האתר ללא מגבלות.</p>
                <h2 class="text-2xl font-bold mt-8 mb-4 text-on-surface">פניות בנושאי נגישות</h2>
                <p>אם נתקלתם בקושי כלשהו בגישה לתוכן באתר, ממונה הנגישות שלנו זמין עבורכם:</p>
                <ul class="list-disc pr-6 text-on-surface mt-4">
                    <li>דוא"ל: <a href="mailto:Office@fractal.co.il" class="text-primary hover:underline">Office@fractal.co.il</a></li>
                    <li>טלפון: <a href="tel:03-6168890" class="text-primary hover:underline dir-ltr inline-block">03-6168890</a></li>
                </ul>
            </div>
        ) : (
            <div class="prose prose-invert max-w-none text-on-surface-variant" dir="ltr">
                <p>Fractal Computers considers accessibility a core value. We have designed this website to meet the WCAG 2.1 AA accessibility standards, ensuring that users with disabilities can navigate, understand, and interact with all critical systems.</p>
                <h2 class="text-2xl font-bold mt-8 mb-4 text-on-surface">Contact Us for Accessibility Needs</h2>
                <p>If you encounter any accessibility barriers on our platform, please reach out directly to our support team:</p>
                <ul class="list-disc pl-6 text-on-surface mt-4">
                    <li>Email: <a href="mailto:Office@fractal.co.il" class="text-primary hover:underline">Office@fractal.co.il</a></li>
                    <li>Phone: <a href="tel:03-6168890" class="text-primary hover:underline">03-6168890</a></li>
                </ul>
            </div>
        )}
    </div>
    <ContactSection lang={lang} />
</Layout>
