<script is:inline>
    function loadAnalytics() {
        console.log("Analytics trackers allowed (consent granted).");
        const gtmId = 'G-989B9CSF2C';
        
        const script = document.createElement('script');
        script.src = `https://www.googletagmanager.com/gtag/js?id=${gtmId}`;
        script.async = true;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gtmId);
        
        // Google Ads Integration (Marketing/Retargeting) 
        gtag('config', 'AW-18053539720');
        
        console.log("Google Analytics and Google Ads injected successfully.");
    }
    if (localStorage.getItem('cookie-consent') === 'granted') {
        loadAnalytics();
    } else {
        window.addEventListener('cookie-consent-granted', loadAnalytics);
    }
</script>
