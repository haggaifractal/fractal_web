---
// ClientsMarquee.astro
export interface Props {
    lang?: 'en' | 'he';
    isMobile?: boolean;
}

const { lang = 'en', isMobile = false } = Astro.props;
const isHe = lang === 'he';

// Reusing the robust client list
const clients = [
  { name: "Amdocs", domain: "amdocs.com" },
  { name: "Assia Medical", domain: "assia.co.il" },
  { name: "T&M Protection Resources", domain: "tmprotection.co.il" },
  { name: "Krausz", domain: "krausz.com" },
  { name: "Natali Healthcare", domain: "natali.co.il" },
  { name: "Moked Emon", domain: "emun.co.il" },
  { name: "Hashmal", domain: "sitonai.co.il" },
  { name: "Tmuna Theater", domain: "tmu-na.org.il" },
  { name: "Leitersdorf Architects", domain: "leitersdorf.com" },
  { name: "Health Center For Women", domain: "bri.co.il" },
  { name: "Ganei Tikva", domain: "ganeytikva.org.il" },
  { name: "L.K. Ltd", domain: "lkltd.co.il" },
  { name: "Maagalot", domain: "producers.org.il" },
  { name: "Resner Software", domain: "rasner.co.il" },
  { name: "AVA Medical", domain: "share.google" }
];
---

<section class={`animate-fade-up w-full overflow-hidden py-4 md:py-5 border-y border-outline-variant/10 relative z-20 shadow-sm ${isMobile ? 'bg-surface/70 backdrop-blur-xl mt-4 mb-4' : 'bg-surface mt-10 md:mt-16'}`} style="--delay: 1100ms" dir="ltr">
    <div class="max-w-7xl mx-auto px-4 mb-4 md:mb-5 text-center" dir={isHe ? 'rtl' : 'ltr'}>
        <p class="text-sm md:text-base font-bold tracking-widest text-on-surface-variant/50 uppercase">
            {isHe ? 'חברות מובילות שסומכות עלינו' : 'Trusted by Innovative Companies'}
        </p>
    </div>
    
    <div class="relative flex overflow-hidden w-full group">
        <!-- Edge Blur Gradients -->
        <div class="absolute left-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-r from-surface to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-l from-surface to-transparent z-10 pointer-events-none"></div>
        
        <div class="flex animate-marquee group-hover:[animation-play-state:paused] whitespace-nowrap">
            <!-- First Loop Set -->
            <div class="flex items-center gap-12 sm:gap-20 px-6 sm:px-10">
                {clients.map((client) => (
                    <div class="flex items-center gap-3 grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-300 select-none cursor-default">
                        <img 
                            src={`/images/clients/${client.domain}.png`} 
                            alt={client.name}
                            class="w-7 h-7 md:w-9 md:h-9 object-contain drop-shadow-sm"
                            onerror="this.style.display='none';"
                        />
                        <span class="text-lg md:text-xl font-bold font-headline text-on-surface-variant">{client.name}</span>
                    </div>
                ))}
            </div>
            <!-- Second Loop Set (Duplicate for seamless infinite scroll) -->
            <div class="flex items-center gap-12 sm:gap-20 px-6 sm:px-10">
                {clients.map((client) => (
                    <div class="flex items-center gap-3 grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-300 select-none cursor-default">
                        <img 
                            src={`/images/clients/${client.domain}.png`} 
                            alt={client.name}
                            class="w-7 h-7 md:w-9 md:h-9 object-contain drop-shadow-sm"
                            onerror="this.style.display='none';"
                        />
                        <span class="text-lg md:text-xl font-bold font-headline text-on-surface-variant">{client.name}</span>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-marquee {
        animation: marquee 35s linear infinite;
        width: max-content;
    }
    /* Hardware acceleration for ultra-smooth scrolling */
    .animate-marquee > div {
        transform: translateZ(0);
        will-change: transform;
    }
</style>
