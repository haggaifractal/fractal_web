---
// ScrollToTop.astro
---
<scroll-to-top>
    <button
        aria-label="Back to top"
        class="fixed bottom-6 end-6 z-50 p-3 rounded-2xl bg-surface/90 backdrop-blur-md border border-outline-variant/20 text-on-surface-variant shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:bg-primary hover:text-white hover:border-primary/50 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,104,87,0.2)] transition-all duration-500 opacity-0 translate-y-10 pointer-events-none flex items-center justify-center group"
    >
        <span class="material-symbols-outlined text-[24px] font-bold group-active:scale-90 transition-transform">keyboard_arrow_up</span>
    </button>
</scroll-to-top>

<script>
    class ScrollToTop extends HTMLElement {
        private btn: HTMLButtonElement | null;
        private boundToggleVisibility: () => void;
        private boundScrollToTop: () => void;

        constructor() {
            super();
            this.btn = this.querySelector('button');
            
            // Bind methods to preserve `this` context
            this.boundToggleVisibility = this.toggleVisibility.bind(this);
            this.boundScrollToTop = this.scrollToTop.bind(this);
        }

        connectedCallback() {
            if (!this.btn) return;
            window.addEventListener('scroll', this.boundToggleVisibility, { passive: true });
            this.btn.addEventListener('click', this.boundScrollToTop);
            
            // Initial check
            this.toggleVisibility();
        }

        disconnectedCallback() {
            if (!this.btn) return;
            window.removeEventListener('scroll', this.boundToggleVisibility);
            this.btn.removeEventListener('click', this.boundScrollToTop);
        }

        toggleVisibility() {
            if (!this.btn) return;
            if (window.scrollY > 400) {
                this.btn.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
                this.btn.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
            } else {
                this.btn.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
                this.btn.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            }
        }

        scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    }

    if (!customElements.get('scroll-to-top')) {
        customElements.define('scroll-to-top', ScrollToTop);
    }
</script>
