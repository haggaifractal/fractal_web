---
export interface Props {
    lang?: 'en' | 'he';
}

const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';

const texts = {
    title: isHe ? 'העדפות פרטיות ועוגיות' : 'Privacy & Cookie Preferences',
    description: isHe 
        ? 'אנו משתמשים בעוגיות לשפר את חוויית הגלישה, לנתח תנועה ולהתאים תוכן. לחץ/י "אישור" להסכמה למעקב על פי החוק.'
        : 'We use cookies to enhance your browsing experience, analyze site traffic, and personalize content. Click "Accept All" to consent.',
    acceptBtn: isHe ? 'אישור וקבלת הכל' : 'Accept All',
    declineBtn: isHe ? 'אפשר הכרחיות בלבד' : 'Essential Only',
    privacyLink: isHe ? '/privacy' : '/en/privacy',
    privacyText: isHe ? 'מדיניות הפרטיות' : 'Privacy Policy',
};
---

<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[100] transform translate-y-full transition-transform duration-500 ease-in-out hidden bg-surface-container-highest border-t border-outline-variant/30 shadow-[0_-15px_40px_rgba(0,0,0,0.08)]">
    <div class={`max-w-7xl mx-auto px-4 py-3 md:px-8 md:py-4 flex flex-col xl:flex-row items-center justify-between gap-3 xl:gap-8 ${isHe ? 'text-right xl:flex-row-reverse' : 'text-left'}`} dir={isHe ? 'rtl' : 'ltr'}>
        
        <div class="flex-1 w-full text-center xl:text-start">
            <p class="text-[13px] md:text-sm text-on-surface-variant font-medium leading-snug">
                <strong class="text-on-surface mx-1">{texts.title}:</strong>
                {texts.description} 
                <a href={texts.privacyLink} class="text-primary hover:underline font-bold mx-1">{texts.privacyText}</a>.
            </p>
        </div>

        <div class={`flex items-center justify-center gap-3 w-full xl:w-auto shrink-0 ${isHe ? 'flex-row-reverse' : ''}`}>
            <button id="cookie-decline" class="flex-1 xl:flex-none px-2 py-2 text-on-surface-variant hover:text-on-surface underline decoration-outline-variant hover:decoration-on-surface font-medium transition-colors text-[13px] md:text-sm whitespace-nowrap">
                {texts.declineBtn}
            </button>
            <button id="cookie-accept" class="flex-1 xl:flex-none px-4 py-2 md:px-5 bg-primary text-white font-bold rounded hover:bg-surface-tint shadow transition-colors text-[13px] md:text-sm whitespace-nowrap">
                {texts.acceptBtn}
            </button>
        </div>

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const banner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('cookie-accept');
        const declineBtn = document.getElementById('cookie-decline');

        // Check if consent has already been given (or declined)
        const consent = localStorage.getItem('cookie-consent');
        
        if (!consent && banner) {
            // Show banner smoothly
            banner.classList.remove('hidden');
            // Allow CSS to render before applying transform
            setTimeout(() => {
                banner.classList.remove('translate-y-full');
            }, 100);
        }

        const hideBanner = () => {
            if (banner) {
                banner.classList.add('translate-y-full');
                setTimeout(() => {
                    banner.classList.add('hidden');
                }, 500); // Matches transition duration
            }
        };

        if (acceptBtn) {
            acceptBtn.addEventListener('click', () => {
                localStorage.setItem('cookie-consent', 'granted');
                hideBanner();
                // Optionally reload or dispatch an event to initialize analytics right away
                window.dispatchEvent(new Event('cookie-consent-granted'));
            });
        }

        if (declineBtn) {
            declineBtn.addEventListener('click', () => {
                localStorage.setItem('cookie-consent', 'denied');
                hideBanner();
            });
        }
    });
</script>
