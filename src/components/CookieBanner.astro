---
export interface Props {
    lang?: 'en' | 'he';
}

const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';

const texts = {
    title: isHe ? 'העדפות פרטיות ועוגיות' : 'Privacy & Cookie Preferences',
    description: isHe 
        ? 'אנו משתמשים בעוגיות כדי לשפר את חוויית הגלישה שלך, לנתח את התנועה באתר, ולהתאים אישית את התוכן. על ידי לחיצה על "אישור וקבלת הכל", אתה מסכים לשימוש שלנו בעוגיות כמתואר במדיניות הפרטיות שלנו.'
        : 'We use cookies to enhance your browsing experience, analyze site traffic, and personalize content. By clicking "Accept All", you consent to our use of cookies as described in our Privacy Policy.',
    acceptBtn: isHe ? 'אישור וקבלת הכל' : 'Accept All',
    declineBtn: isHe ? 'סרב למעקב' : 'Decline',
    privacyLink: isHe ? '/he/privacy' : '/privacy',
    privacyText: isHe ? 'מדיניות פרטיות' : 'Privacy Policy',
};
---

<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 transform translate-y-full transition-transform duration-500 ease-in-out hidden">
    <div class="bg-surface-container-highest border-t border-outline-variant/30 shadow-2xl p-6 md:p-8">
        <div class={`max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 ${isHe ? 'text-right md:flex-row-reverse' : 'text-left'}`} dir={isHe ? 'rtl' : 'ltr'}>
            
            <div class="flex-1">
                <h3 class="text-xl font-bold text-on-surface mb-2 font-headline">{texts.title}</h3>
                <p class="text-sm text-on-surface-variant leading-relaxed">
                    {texts.description} 
                    <a href={texts.privacyLink} class="text-primary hover:underline font-bold mr-1 ml-1">{texts.privacyText}</a>.
                </p>
            </div>

            <div class={`flex items-center gap-4 w-full md:w-auto ${isHe ? 'flex-row-reverse' : ''}`}>
                <button id="cookie-decline" class="flex-1 md:flex-none px-6 py-3 border border-outline-variant text-on-surface font-bold rounded-lg hover:bg-surface-variant transition-colors text-sm">
                    {texts.declineBtn}
                </button>
                <button id="cookie-accept" class="flex-1 md:flex-none px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-surface-tint shadow-lg transition-colors text-sm">
                    {texts.acceptBtn}
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const banner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('cookie-accept');
        const declineBtn = document.getElementById('cookie-decline');

        // Check if consent has already been given (or declined)
        const consent = localStorage.getItem('cookie-consent');
        
        if (!consent && banner) {
            // Show banner smoothly
            banner.classList.remove('hidden');
            // Allow CSS to render before applying transform
            setTimeout(() => {
                banner.classList.remove('translate-y-full');
            }, 100);
        }

        const hideBanner = () => {
            if (banner) {
                banner.classList.add('translate-y-full');
                setTimeout(() => {
                    banner.classList.add('hidden');
                }, 500); // Matches transition duration
            }
        };

        if (acceptBtn) {
            acceptBtn.addEventListener('click', () => {
                localStorage.setItem('cookie-consent', 'granted');
                hideBanner();
                // Optionally reload or dispatch an event to initialize analytics right away
                window.dispatchEvent(new Event('cookie-consent-granted'));
            });
        }

        if (declineBtn) {
            declineBtn.addEventListener('click', () => {
                localStorage.setItem('cookie-consent', 'denied');
                hideBanner();
            });
        }
    });
</script>
