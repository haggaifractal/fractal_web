---
export interface Props {
    lang?: 'en' | 'he';
}

const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';

const texts = {
    address_title: isHe ? 'כתובת' : 'Address',
    address_body1: isHe ? "רח' מצדה 8, בני ברק," : '8 Masada St., Bney Brak,',
    address_body2: isHe ? 'ת.ד. 2505, מיקוד 51124' : 'P.O.B. 2505, Zip Code 51124',
    contact_title: isHe ? 'צור קשר' : 'Contact',
    tel: isHe ? 'טלפון 03-6168890' : 'Tel. 03-6168890',
    email: 'Office@fractal.co.il',
    legal_title: isHe ? 'מידע משפטי' : 'Legal',
    terms: isHe ? 'תנאי שימוש' : 'Terms of Use',
    privacy: isHe ? 'הצהרת פרטיות' : 'Privacy Policy',
    accessibility: isHe ? 'הצהרת נגישות' : 'Accessibility Statement',
    rights: '© Fractal Computers & Communications 2002 Ltd.',
    waze: 'Waze',
    google_maps: 'Google Maps'
};

const links = {
    terms: isHe ? '/terms' : '/en/terms',
    privacy: isHe ? '/privacy' : '/en/privacy',
    accessibility: isHe ? '/accessibility' : '/en/accessibility',
    waze: isHe ? 'https://waze.com/ul?ll=32.0913,34.8239&navigate=yes' : 'https://waze.com/ul?ll=32.0913,34.8239&navigate=yes',
    gmaps: isHe ? 'https://maps.google.com/?q=מצדה+8+בני+ברק' : 'https://maps.google.com/?q=8+Masada+St,+Bnei+Brak,+Israel'
};
---

<footer class="bg-[#001712] pt-16 pb-8 rounded-t-[3rem] relative overflow-hidden mt-auto w-full">
    <!-- Ambient Glow Background -->
    <div class="absolute inset-0 w-full h-full z-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute -bottom-[50%] left-[20%] w-[60vw] h-[60vw] min-w-[300px] bg-primary/10 blur-[120px] rounded-full"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-8 relative z-10 w-full flex flex-col text-white/70 text-sm" dir={isHe ? 'rtl' : 'ltr'}>
        <!-- Centered Layout for Address and Contact -->
        <div class="flex flex-col md:flex-row justify-center items-center text-center gap-10 md:gap-24 w-full mb-12">
            
            <div class="flex flex-col items-center gap-3">
                <h4 class="text-primary-fixed font-bold uppercase tracking-widest text-xs">{texts.address_title}</h4>
                <p class="leading-relaxed">{texts.address_body1}<br/>{texts.address_body2}</p>
                <div class="flex flex-wrap justify-center gap-3 mt-4 text-sm font-bold text-primary-fixed">
                    <a href={links.gmaps} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-white hover:bg-white/5 border border-primary-fixed/20 bg-primary-fixed/10 px-4 py-2 rounded-full transition-all group shadow-sm shadow-primary/5 active:scale-95" aria-label="Google Maps">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current opacity-80 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24">
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                        </svg>
                        <span>{texts.google_maps}</span>
                    </a>
                    <a href={links.waze} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-white hover:bg-white/5 border border-primary-fixed/20 bg-primary-fixed/10 px-4 py-2 rounded-full transition-all group shadow-sm shadow-primary/5 active:scale-95" aria-label="Waze">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 fill-current opacity-80 group-hover:opacity-100 transition-opacity" viewBox="0 0 512 512">
                            <path d="M495.6 156.4c-8.9-38.3-26.6-70.2-52.7-94.8-21.7-20.5-47.5-35-77-43-34.9-9.5-72.3-10.7-108.6-4.5-38.2 6.5-73.4 22.2-103.4 46.5-27.4 22.3-48.4 51.5-61 85.3-10.6 28.5-15.8 59.2-15 90.1.7 28 5.7 55.4 14.8 81.3-49.8 1.9-88.7 8.3-90.1 8.5-4.4.7-7.8 4.2-8.5 8.7-.7 4.5.9 9.1 4.3 12.1 27.6 24 64.9 36.6 102.7 34.6 23.6 29 55.7 50.4 92.5 60.1 36.6 9.7 75.3 10.3 111.9 2 34.6-7.8 66-23.7 90.9-46.7 22.3-20.6 39.5-46.8 49.3-76.3 8.3-24.8 12.6-51.2 12.5-77.8-.1-29-4.8-58.1-13.8-86.1zM172 268.1c-14.7 0-26.6-11.9-26.6-26.6 0-14.7 11.9-26.6 26.6-26.6 14.7 0 26.6 11.9 26.6 26.6 0 14.7-11.9 26.6-26.6 26.6zm144.1 53.2c-12.7 16.3-33.1 25.1-54.1 25.1s-41.4-8.8-54.1-25.1c-4.4-5.6-3.4-13.8 2.2-18.1 5.6-4.4 13.8-3.4 18.1 2.2 6.4 8.2 18.5 14.3 33.7 14.3 15.2 0 27.3-6.1 33.7-14.3 4.4-5.6 12.6-6.6 18.1-2.2 5.7 4.3 6.7 12.5 2.4 18.1zm23.9-53.2c-14.7 0-26.6-11.9-26.6-26.6 0-14.7 11.9-26.6 26.6-26.6 14.7 0 26.6 11.9 26.6 26.6 0 14.7-11.9 26.6-26.6 26.6z"/>
                            <path d="M141.6 447.8c0 35.4-28.7 64.1-64.1 64.1s-64.1-28.7-64.1-64.1 28.7-64.1 64.1-64.1 64.1 28.7 64.1 64.1zm299.7 0c0 35.4-28.7 64.1-64.1 64.1s-64.1-28.7-64.1-64.1 28.7-64.1 64.1-64.1 64.1 28.7 64.1 64.1z"/>
                        </svg>
                        <span>{texts.waze}</span>
                    </a>
                </div>
            </div>
            
            <div class="flex flex-col items-center gap-3">
                <h4 class="text-primary-fixed font-bold uppercase tracking-widest text-xs">{texts.contact_title}</h4>
                <div class="flex items-center gap-2 w-fit shrink-0" dir="ltr">
                    <a href="tel:03-6168890" class="hover:text-white transition-colors block" dir="ltr">{texts.tel}</a>
                    <button aria-label="Copy phone" class="group flex items-center justify-center bg-white/5 hover:bg-white/10 p-1.5 rounded-full transition-colors" onclick="navigator.clipboard.writeText('03-6168890'); this.querySelector('.copy-icon').textContent='check'; this.querySelector('.copy-icon').classList.add('text-primary-fixed'); setTimeout(()=>{this.querySelector('.copy-icon').textContent='content_copy'; this.querySelector('.copy-icon').classList.remove('text-primary-fixed');},2000);">
                        <span class="material-symbols-outlined text-[13px] opacity-60 group-hover:opacity-100 transition-all copy-icon">content_copy</span>
                    </button>
                </div>
                <div class="flex items-center gap-2 w-fit shrink-0" dir="ltr">
                    <a href="#" onclick="window.location.href = 'mailto:' + ['Office', 'fractal.co.il'].join('@'); return false;" class="hover:text-white transition-colors block">{texts.email}</a>
                    <button aria-label="Copy email" class="group flex items-center justify-center bg-white/5 hover:bg-white/10 p-1.5 rounded-full transition-colors" onclick="navigator.clipboard.writeText('Office@fractal.co.il'); this.querySelector('.copy-icon').textContent='check'; this.querySelector('.copy-icon').classList.add('text-primary-fixed'); setTimeout(()=>{this.querySelector('.copy-icon').textContent='content_copy'; this.querySelector('.copy-icon').classList.remove('text-primary-fixed');},2000);">
                        <span class="material-symbols-outlined text-[13px] opacity-60 group-hover:opacity-100 transition-all copy-icon">content_copy</span>
                    </button>
                </div>
            </div>
            
        </div>

        <div class="flex flex-col items-center gap-3 mt-auto border-t border-white/10 pt-8">
            <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white/80">
                <a href={links.terms} class="hover:text-white transition-colors">{texts.terms}</a>
                <a href={links.privacy} class="hover:text-white transition-colors">{texts.privacy}</a>
                <a href={links.accessibility} class="hover:text-white transition-colors">{texts.accessibility}</a>
            </div>
            <div class="text-xs font-medium opacity-60 text-center" dir="ltr">
                {texts.rights}
            </div>
        </div>
    </div>
</footer>
