---
import Icon from './Icon.astro';
import WazeIcon from './icons/WazeIcon.astro';
export interface Props {
    lang?: 'en' | 'he';
}

const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';

const texts = {
    address_title: isHe ? 'כתובת' : 'Address',
    address_body1: isHe ? "רח' מצדה 8, בני ברק," : '8 Masada St., Bney Brak,',
    address_body2: isHe ? 'ת.ד. 2505, מיקוד 51124' : 'P.O.B. 2505, Zip Code 51124',
    contact_title: isHe ? 'צור קשר' : 'Contact',
    tel: isHe ? 'טלפון 03-6168890' : 'Tel. 03-6168890',
    email: 'Office@fractal.co.il',
    legal_title: isHe ? 'מידע משפטי' : 'Legal',
    terms: isHe ? 'תנאי שימוש' : 'Terms of Use',
    privacy: isHe ? 'הצהרת פרטיות' : 'Privacy Policy',
    accessibility: isHe ? 'הצהרת נגישות' : 'Accessibility Statement',
    rights: '© Fractal Computers & Communications 2002 Ltd.',
    waze: 'Waze',
    google_maps: 'Google Maps'
};

const links = {
    terms: isHe ? '/terms' : '/en/terms',
    privacy: isHe ? '/privacy' : '/en/privacy',
    accessibility: isHe ? '/accessibility' : '/en/accessibility',
    waze: isHe ? 'https://waze.com/ul?ll=32.0913,34.8239&navigate=yes' : 'https://waze.com/ul?ll=32.0913,34.8239&navigate=yes',
    gmaps: isHe ? 'https://maps.google.com/?q=מצדה+8+בני+ברק' : 'https://maps.google.com/?q=8+Masada+St,+Bnei+Brak,+Israel'
};
---

<footer class="bg-[#001712] pt-16 pb-8 rounded-t-[3rem] relative overflow-hidden mt-auto w-full">
    <!-- Ambient Glow Background -->
    <div class="absolute inset-0 w-full h-full z-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute -bottom-[50%] left-[20%] w-[60vw] h-[60vw] min-w-[300px] bg-primary/10 blur-[120px] rounded-full"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-8 relative z-10 w-full flex flex-col text-white/70 text-sm" dir={isHe ? 'rtl' : 'ltr'}>
        <!-- Centered Layout for Address and Contact -->
        <div class="flex flex-col md:flex-row justify-center items-center text-center gap-10 md:gap-24 w-full mb-12">
            
            <div class="flex flex-col items-center gap-3">
                <h4 class="text-primary-fixed font-bold uppercase tracking-widest text-xs">{texts.address_title}</h4>
                <p class="leading-relaxed">{texts.address_body1}<br/>{texts.address_body2}</p>
                <div class="flex flex-wrap justify-center gap-4 mt-4 text-sm font-bold text-primary-fixed">
                    <a href={links.gmaps} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-white/5 hover:bg-white/10 border border-white/5 hover:border-primary/40 px-5 py-2.5 rounded-2xl transition-all duration-300 group shadow-md hover:shadow-primary/20 active:scale-95" aria-label="Google Maps">
                        <Icon name="location_on" class="text-xl text-primary-fixed group-hover:scale-110 group-hover:-translate-y-1 transition-transform duration-300" />
                        <span class="font-medium text-sm text-white/90 group-hover:text-white tracking-wide">{texts.google_maps}</span>
                    </a>
                    <a href={links.waze} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-white/5 hover:bg-white/10 border border-white/5 hover:border-primary/40 px-5 py-2.5 rounded-2xl transition-all duration-300 group shadow-md hover:shadow-primary/20 active:scale-95" aria-label="Waze">
                        <WazeIcon class="w-5 h-5 text-primary-fixed group-hover:scale-110 group-hover:-rotate-6 transition-transform duration-300" />
                        <span class="font-medium text-sm text-white/90 group-hover:text-white tracking-wide">{texts.waze}</span>
                    </a>
                </div>
            </div>
            
            <div class="flex flex-col items-center gap-3">
                <h4 class="text-primary-fixed font-bold uppercase tracking-widest text-xs">{texts.contact_title}</h4>
                <div class="flex items-center gap-2 w-fit shrink-0" dir="ltr">
                    <a href="tel:03-6168890" class="hover:text-white transition-colors block" dir="ltr">{texts.tel}</a>
                    <button aria-label="Copy phone" class="group flex items-center justify-center bg-white/5 hover:bg-white/10 w-7 h-7 rounded-full transition-colors relative" onclick="navigator.clipboard.writeText('03-6168890'); this.querySelector('.copy-icon').style.opacity='0'; this.querySelector('.check-icon').style.opacity='1'; setTimeout(()=>{this.querySelector('.copy-icon').style.opacity=''; this.querySelector('.check-icon').style.opacity='0';},2000);">
                        <Icon name="content_copy" class="absolute text-[13px] opacity-60 group-hover:opacity-100 transition-opacity copy-icon" />
                        <Icon name="check" class="absolute text-[13px] opacity-0 transition-opacity text-primary-fixed check-icon" />
                    </button>
                </div>
                <div class="flex items-center gap-2 w-fit shrink-0" dir="ltr">
                    <a href="#" onclick="window.location.href = 'mailto:' + ['Office', 'fractal.co.il'].join('@'); return false;" class="hover:text-white transition-colors block">{texts.email}</a>
                    <button aria-label="Copy email" class="group flex items-center justify-center bg-white/5 hover:bg-white/10 w-7 h-7 rounded-full transition-colors relative" onclick="navigator.clipboard.writeText('Office@fractal.co.il'); this.querySelector('.copy-icon').style.opacity='0'; this.querySelector('.check-icon').style.opacity='1'; setTimeout(()=>{this.querySelector('.copy-icon').style.opacity=''; this.querySelector('.check-icon').style.opacity='0';},2000);">
                        <Icon name="content_copy" class="absolute text-[13px] opacity-60 group-hover:opacity-100 transition-opacity copy-icon" />
                        <Icon name="check" class="absolute text-[13px] opacity-0 transition-opacity text-primary-fixed check-icon" />
                    </button>
                </div>
            </div>
            
        </div>

        <div class="flex flex-col items-center gap-3 mt-auto border-t border-white/10 pt-8">
            <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white/80">
                <a href={links.terms} class="hover:text-white transition-colors">{texts.terms}</a>
                <a href={links.privacy} class="hover:text-white transition-colors">{texts.privacy}</a>
                <a href={links.accessibility} class="hover:text-white transition-colors">{texts.accessibility}</a>
            </div>
            <div class="text-xs font-medium opacity-60 text-center" dir="ltr">
                {texts.rights}
            </div>
        </div>
    </div>
</footer>
