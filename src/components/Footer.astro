---
export interface Props {
    lang?: 'en' | 'he';
}

const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';

const texts = {
    address_title: isHe ? 'כתובת' : 'Address',
    address_body1: isHe ? "רח' מצדה 8, בני ברק," : '8 Masada St., Bney Brak,',
    address_body2: isHe ? 'ת.ד. 2505, מיקוד 51124' : 'P.O.B. 2505, Zip Code 51124',
    contact_title: isHe ? 'צור קשר' : 'Contact',
    tel: isHe ? 'טלפון 03-6168890' : 'Tel. 03-6168890',
    email: 'Office@fractal.co.il',
    legal_title: isHe ? 'מידע משפטי' : 'Legal',
    terms: isHe ? 'תנאי שימוש' : 'Terms of Use',
    privacy: isHe ? 'הצהרת פרטיות' : 'Privacy Policy',
    accessibility: isHe ? 'הצהרת נגישות' : 'Accessibility Statement',
    rights: '© Fractal Computers & Communications 2002 Ltd.',
    waze: 'Waze',
    google_maps: 'Google Maps'
};

const links = {
    terms: isHe ? '/he/terms' : '/terms',
    privacy: isHe ? '/he/privacy' : '/privacy',
    accessibility: isHe ? '/he/accessibility' : '/accessibility',
    waze: isHe ? 'https://waze.com/ul?ll=32.0913,34.8239&navigate=yes' : 'https://waze.com/ul?ll=32.0913,34.8239&navigate=yes',
    gmaps: isHe ? 'https://maps.google.com/?q=מצדה+8+בני+ברק' : 'https://maps.google.com/?q=8+Masada+St,+Bnei+Brak,+Israel'
};
---

<footer class="bg-[#001712] pt-16 pb-8 rounded-t-[3rem] relative overflow-hidden mt-auto w-full">
    <!-- Ambient Glow Background -->
    <div class="absolute inset-0 w-full h-full z-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute -bottom-[50%] left-[20%] w-[60vw] h-[60vw] min-w-[300px] bg-primary/10 blur-[120px] rounded-full"></div>
    </div>
    
    <div class="max-w-6xl mx-auto px-8 relative z-10 w-full flex flex-col text-white/70 text-sm" dir={isHe ? 'rtl' : 'ltr'}>
        <!-- Centered Layout for Address and Contact -->
        <div class="flex flex-col md:flex-row justify-center items-center text-center gap-10 md:gap-24 w-full mb-12">
            
            <div class="flex flex-col items-center gap-3">
                <h4 class="text-primary-fixed font-bold uppercase tracking-widest text-xs">{texts.address_title}</h4>
                <p class="leading-relaxed">{texts.address_body1}<br/>{texts.address_body2}</p>
                <div class="flex flex-wrap justify-center gap-4 mt-1 text-xs font-medium text-primary-fixed">
                    <a href={links.waze} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors underline underline-offset-4">{texts.waze}</a>
                    <a href={links.gmaps} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors underline underline-offset-4">{texts.google_maps}</a>
                </div>
            </div>
            
            <div class="flex flex-col items-center gap-3">
                <h4 class="text-primary-fixed font-bold uppercase tracking-widest text-xs">{texts.contact_title}</h4>
                <a href="tel:03-6168890" class="hover:text-white transition-colors block w-fit shrink-0" dir={isHe ? 'ltr' : 'ltr'}>{texts.tel}</a>
                <a href="#" onclick="window.location.href = 'mailto:' + ['Office', 'fractal.co.il'].join('@'); return false;" class="hover:text-white transition-colors block w-fit shrink-0">{texts.email}</a>
            </div>
            
        </div>

        <div class="flex flex-col items-center gap-3 mt-auto border-t border-white/10 pt-8">
            <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white/80">
                <a href={links.terms} class="hover:text-white transition-colors">{texts.terms}</a>
                <a href={links.privacy} class="hover:text-white transition-colors">{texts.privacy}</a>
                <a href={links.accessibility} class="hover:text-white transition-colors">{texts.accessibility}</a>
            </div>
            <div class="text-xs font-medium opacity-60 text-center" dir="ltr">
                {texts.rights}
            </div>
        </div>
    </div>
</footer>
