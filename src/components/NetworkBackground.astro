---
// NetworkBackground.astro (Modern Mesh Gradient with Fractal texture)
---
<div class="absolute inset-0 w-full h-full z-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 bg-surface"></div>
    <!-- Mesh Gradient Blobs -->
    <div class="absolute inset-0 overflow-hidden">
        <!-- Deep Brand Teal Glowing Orb -->
        <div class="absolute top-[-10%] left-[-10%] w-[60vw] h-[60vw] min-w-[400px] min-h-[400px] bg-[#006874] opacity-[0.22] blur-[120px] rounded-full animate-mesh-1"></div>
        <!-- Bright Cyan Glowing Orb -->
        <div class="absolute top-[5%] right-[-10%] w-[50vw] h-[50vw] min-w-[350px] min-h-[350px] bg-[#00E5FF] opacity-[0.12] blur-[100px] rounded-full animate-mesh-2"></div>
        <!-- Subtle Emerald Center Orb -->
        <div class="absolute bottom-[-15%] left-[20%] w-[55vw] h-[55vw] min-w-[300px] min-h-[300px] bg-[#00A388] opacity-[0.18] blur-[130px] rounded-full animate-mesh-3"></div>
        <!-- Center bright glow -->
        <div class="absolute top-[35%] left-[45%] w-[40vw] h-[40vw] min-w-[200px] min-h-[200px] bg-[#97F0FF] opacity-[0.10] blur-[140px] rounded-full animate-mesh-4"></div>
    </div>
    
    <!-- Subtle SVG Noise Filter for "Fractal" texture -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.04] mix-blend-overlay" xmlns="http://www.w3.org/2000/svg">
        <filter id="fractalNoise">
            <feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="3" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#fractalNoise)" />
    </svg>
</div>

<style>
    @keyframes mesh1 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(8%, 10%) scale(1.05); }
        50% { transform: translate(-4%, 5%) scale(0.95); }
        75% { transform: translate(-10%, -8%) scale(1.02); }
    }
    @keyframes mesh2 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(-12%, 8%) scale(1.1); }
        66% { transform: translate(5%, -15%) scale(0.9); }
    }
    @keyframes mesh3 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(15%, -10%) scale(1.08); }
    }
    @keyframes mesh4 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(-8%, -15%) scale(0.95); }
        66% { transform: translate(10%, 5%) scale(1.1); }
    }
    .animate-mesh-1 { animation: mesh1 22s infinite cubic-bezier(0.4, 0, 0.2, 1); }
    .animate-mesh-2 { animation: mesh2 28s infinite cubic-bezier(0.4, 0, 0.2, 1); }
    .animate-mesh-3 { animation: mesh3 26s infinite cubic-bezier(0.4, 0, 0.2, 1); }
    .animate-mesh-4 { animation: mesh4 32s infinite cubic-bezier(0.4, 0, 0.2, 1); }
</style>
