---
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
interface Props {
	title: string;
	description?: string;
}

const { title, description = "פרקטל מתמחה במתן פתרונות מחשוב מלאים, שירות ותמיכה טכנית מתקדמת ללקוחות עסקיים ותעשייתיים השואפים למצוינות." } = Astro.props;
const pathname = Astro.url.pathname;
const enPath = '/en' + (pathname === '/' ? '' : pathname);
const ogImageUrl = new URL('/og-image.jpg', Astro.url).href;
---

<!doctype html>
<html lang="he" dir="rtl" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/logo-icon.png" />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | פרקטל - מחשוב בגישה עסקית</title>
    <meta property="og:title" content={`${title} | פרקטל - מחשוב בגישה עסקית`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <ClientRouter />

    <script is:inline>
        (function() {
            try {
                if (history.scrollRestoration) {
                    history.scrollRestoration = 'manual';
                }
                var override = localStorage.getItem('lang');
                var isEn = window.location.pathname.startsWith('/en');
                var path = window.location.pathname;
                if (!isEn && override === 'en') {
                    window.location.replace('/en' + path + window.location.search + window.location.hash);
                } else if (isEn && override === 'he') {
                    var newPath = path.replace(/^\/en/, '');
                    window.location.replace((newPath || '/') + window.location.search + window.location.hash);
                }
            } catch (e) {}
        })();
    </script>

    <!-- Heebo for high-quality Hebrew typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <style is:global>
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        :root {
            --color-primary: 0, 104, 116;
            --color-on-primary: 255, 255, 255;
            --color-primary-container: 151, 240, 255;
            --color-on-primary-container: 0, 31, 36;
            --color-secondary: 74, 98, 103;
            --color-surface: 244, 250, 250;
            --color-on-surface: 22, 29, 29;
            --color-outline: 111, 121, 122;
        }
        
        body {
            font-family: 'Heebo', sans-serif;
            background-color: rgb(var(--color-surface));
            color: rgb(var(--color-on-surface));
        }

        .font-headline {
            font-family: 'Heebo', sans-serif;
        }
    </style>
</head>
<body class="bg-surface text-on-surface selection:bg-primary-fixed selection:text-on-primary-fixed flex flex-col min-h-screen">
    <nav id="main-nav-he" class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center px-4 md:px-8 py-2 md:py-3 transition-all duration-300 bg-white/70 dark:bg-emerald-950/70 backdrop-blur-xl rounded-[2rem] mt-3 mx-3 md:mx-auto max-w-6xl shadow-[0_20px_40px_rgba(0,104,87,0.06)]">
        <div class="flex items-center relative z-10 transition-transform hover:scale-105 active:scale-95 duration-300">
            <a href="/" class="group flex items-center gap-2 md:gap-3 no-underline outline-none">
                <img id="nav-logo-he" src="/logo-icon.png" alt="Fractal Logo Icon" width="64" height="64" class="w-16 h-16 lg:w-28 lg:h-28 object-contain shrink-0 drop-shadow-xl -mr-2 -my-2 lg:-mr-4 lg:-my-6 transition-all duration-300" />

                <div class="flex flex-col justify-center">
                    <span class="text-2xl lg:text-3xl font-bold text-slate-800 tracking-tight leading-none translate-y-[1px]" style="font-family: Arial, Helvetica, sans-serif;">FRACTAL</span>
                    <span class="text-[0.55rem] lg:text-[0.65rem] font-bold tracking-[0.16em] text-emerald-700/90 uppercase leading-none mt-1">מחשוב בגישה עסקית</span>
                </div>
            </a>
        </div>
        <div class="hidden lg:flex flex-1 items-center justify-center pt-1 transition-all">
            <!-- Centered Navigation Links -->
            <div class="flex items-center justify-center w-full gap-6 xl:gap-10">
                <a href="/" class="whitespace-nowrap shrink-0 text-on-surface-variant font-medium hover:text-primary transition-colors text-[15px] tracking-wide relative group">ראשי<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span></a>
                <a href="/about" class="whitespace-nowrap shrink-0 text-on-surface-variant font-medium hover:text-primary transition-colors text-[15px] tracking-wide relative group">אודותינו<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span></a>
                <a href="/services" class="whitespace-nowrap shrink-0 text-on-surface-variant font-medium hover:text-primary transition-colors text-[15px] tracking-wide relative group">השירותים שלנו<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span></a>
                <a href="/customers" class="whitespace-nowrap shrink-0 text-on-surface-variant font-medium hover:text-primary transition-colors text-[15px] tracking-wide relative group">לקוחות<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span></a>
            </div>
        </div>

        <div class="flex items-center gap-2 sm:gap-4 relative z-10 shrink-0">
            <!-- Language Switcher (Desktop) -->
            <a href={enPath} onclick="localStorage.setItem('lang', 'en');" class="hidden lg:flex text-on-surface-variant hover:text-primary transition-colors text-sm font-bold tracking-wide items-center font-headline uppercase" dir="ltr">EN</a>
            
            <div class="hidden lg:block h-5 w-px bg-outline-variant/30"></div>

            <!-- Contact Icons (Desktop & Tablet) -->
            <div class="hidden md:flex items-center gap-2">
                <a href="tel:03-6168890" class="flex items-center justify-center w-10 h-10 rounded-full bg-surface-variant/80 text-on-surface-variant hover:bg-primary hover:text-white transition-all hover:scale-105 active:scale-95" aria-label="התקשר אלינו">
                    <span class="material-symbols-outlined text-[20px]">call</span>
                </a>
                <a href="#" onclick="window.location.href='mailto:Office@fractal.co.il'; return false;" class="flex items-center justify-center w-10 h-10 rounded-full bg-surface-variant/80 text-on-surface-variant hover:bg-primary hover:text-white transition-all hover:scale-105 active:scale-95" aria-label="שלח לנו מייל">
                    <span class="material-symbols-outlined text-[20px]">mail</span>
                </a>
            </div>

            <div class="hidden md:block h-5 w-px bg-outline-variant/30"></div>

            <!-- Tech Support Button (Desktop Only) -->
            <a href="https://f2002.net/" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex px-4 py-2 sm:px-6 sm:py-2.5 bg-gradient-to-br from-primary to-primary-container text-white rounded-full text-xs sm:text-sm font-semibold hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20 whitespace-nowrap">תמיכה טכנית</a>
            
            <!-- Mobile Menu Toggle -->
            <button id="mobile-btn-he" class="lg:hidden flex items-center justify-center p-2 rounded-full bg-surface-variant/80 text-on-surface hover:bg-primary hover:text-white transition-all" aria-label="Toggle Menu">
                <span class="material-symbols-outlined" id="mobile-icon-he">menu</span>
            </button>
        </div>
    </nav>
    
    <!-- Mobile Full-Screen Overlay (RTL) -->
    <div id="mobile-nav-he" class="fixed inset-0 z-[45] bg-surface/95 backdrop-blur-3xl opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden flex flex-col pt-32 px-6 overscroll-none">
        <div class="flex flex-col gap-2">
            <!-- Language Switcher (Mobile) - Top Left (justify-end in RTL) -->
            <div class="flex justify-end px-6 mb-2">
                <a href={enPath} onclick="localStorage.setItem('lang', 'en');" class="text-on-surface-variant hover:text-primary transition-colors text-lg font-bold tracking-wide font-headline uppercase" dir="ltr">EN</a>
            </div>

            <a href="/" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group">
                ראשי <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_left</span>
            </a>
            <a href="/about" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group">
                אודותינו <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_left</span>
            </a>
            <a href="/services" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group">
                השירותים שלנו <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_left</span>
            </a>
            <a href="/customers" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group">
                לקוחות <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_left</span>
            </a>
            <a href="/#contact" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group" onclick="document.getElementById('mobile-btn-he').click()">
                צור קשר <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_left</span>
            </a>
            
            <div class="mt-8 px-6">
                <!-- Tech Support Button (Mobile Menu) -->
                <a href="https://f2002.net/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full py-4 bg-gradient-to-br from-primary to-primary-container text-white font-bold rounded-xl shadow-lg shadow-primary/20 active:scale-95 transition-all">
                    <span class="material-symbols-outlined text-xl">support_agent</span> 
                    תמיכה טכנית
                </a>
            </div>
        </div>
    </div>

    <script is:inline>
        document.addEventListener('astro:page-load', () => {
            const btn = document.getElementById('mobile-btn-he');
            const nav = document.getElementById('mobile-nav-he');
            const icon = document.getElementById('mobile-icon-he');
            const links = nav ? nav.querySelectorAll('a') : [];
            let menuOpen = false;

            if(btn && nav && icon) {
                const toggleMenu = () => {
                    menuOpen = !menuOpen;
                    if(menuOpen) {
                        nav.classList.remove('opacity-0', 'pointer-events-none');
                        nav.classList.add('opacity-100', 'pointer-events-auto');
                        icon.textContent = 'close';
                        document.body.style.overflow = 'hidden';
                    } else {
                        nav.classList.add('opacity-0', 'pointer-events-none');
                        nav.classList.remove('opacity-100', 'pointer-events-auto');
                        icon.textContent = 'menu';
                        document.body.style.overflow = '';
                    }
                };

                // Clear previous listeners (robustness)
                const newBtn = btn.cloneNode(true);
                if (btn.parentNode) btn.parentNode.replaceChild(newBtn, btn);
                newBtn.addEventListener('click', toggleMenu);
                
                links.forEach(link => {
                    link.addEventListener('click', () => {
                        if (menuOpen) toggleMenu();
                    });
                });
            }

            // Phase 3: Dynamic Header
            const mainNav = document.getElementById('main-nav-he');
            const navLogo = document.getElementById('nav-logo-he');
            const checkScroll = () => {
                if (window.scrollY > 50) {
                    mainNav?.classList.add('bg-white/90', 'shadow-md', 'py-1');
                    mainNav?.classList.remove('bg-white/70', 'py-2', 'md:py-3', 'shadow-[0_20px_40px_rgba(0,104,87,0.06)]');
                    navLogo?.classList.add('scale-75'); 
                } else {
                    mainNav?.classList.add('bg-white/70', 'py-2', 'md:py-3', 'shadow-[0_20px_40px_rgba(0,104,87,0.06)]');
                    mainNav?.classList.remove('bg-white/90', 'shadow-md', 'py-1');
                    navLogo?.classList.remove('scale-75');
                }
            };
            window.addEventListener('scroll', checkScroll);
            checkScroll();

            // Phase 2: Scroll Reveal Animations
            const observerOptions = { root: null, rootMargin: '0px', threshold: 0.05 };
            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);
            
            document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));

            // Safety fallback: if anything remained hidden, just show it after 2 seconds
            setTimeout(() => {
                document.querySelectorAll('.reveal-on-scroll:not(.is-visible)').forEach(el => {
                    el.classList.add('is-visible');
                    observer.unobserve(el);
                });
            }, 2000);
        });
    </script>

    <main class="flex-grow w-full pb-16 pt-24 relative z-0">
        <slot />
    </main>

    <Footer lang="he" />
    <CookieBanner lang="he" />
    <ScrollToTop />

    <!-- Future Analytics Placeholder (Amendment 13 Privacy by Design) -->
    <script is:inline>
        function loadAnalytics() {
            // TODO: Inject actual Google Analytics or Meta Pixel tags here
            console.log("Analytics trackers allowed (consent granted).");
        }
        
        if (localStorage.getItem('cookie-consent') === 'granted') {
            loadAnalytics();
        } else {
            window.addEventListener('cookie-consent-granted', loadAnalytics);
        }
    </script>

    <!-- Open Source Accessibility Widget -->
    <script>
        import { Accessibility } from 'accessibility';

        window.addEventListener('load', function() {
            new Accessibility({
                labels: {
                    menuTitle: 'אפשרויות נגישות',
                    increaseText: 'הגדל טקסט',
                    decreaseText: 'הקטן טקסט',
                    increaseTextSpacing: 'הגדל מרווח טקסט',
                    decreaseTextSpacing: 'הקטן מרווח טקסט',
                    increaseLineHeight: 'הגדל מרווח שורות',
                    decreaseLineHeight: 'הקטן מרווח שורות',
                    invertColors: 'הפוך צבעים',
                    grayHues: 'גווני אפור',
                    underlineLinks: 'קו תחתון לקישורים',
                    bigCursor: 'סמן גדול',
                    readingGuide: 'מדריך קריאה',
                    textToSpeech: 'הקראת טקסט',
                    speechToText: 'הכתבה קולית',
                    resetTitle: 'איפוס נגישות',
                    closeTitle: 'סגור'
                },
                icon: {
                    position: {
                        bottom: { size: 30, units: 'px' },
                        right: { size: 30, units: 'px' },
                        type: 'fixed'
                    }
                }
            });
        }, false);
    </script>

    <style is:global>
        /* Force RTL styling onto the accessibility widget elements */
        .accessibility-menu { direction: rtl; text-align: right; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-in {
            animation: fadeIn ease-out forwards;
        }
        .animate-fade-up {
            opacity: 0;
            animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            animation-delay: var(--delay, 0ms);
        }
        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal-on-scroll.is-visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</body>
</html>
