---
// src/layouts/Layout.astro
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

export interface Props {
	title: string;
	description?: string;
}

const { title, description = "Fractal specializes in providing IT consulting and support solutions to business and industrial customers who expect excellence." } = Astro.props;
const pathname = Astro.url.pathname;
const hePath = pathname.replace(/^\/en/, '') || '/';
const ogImageUrl = new URL('/og-image.jpg', Astro.url).href;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/logo-icon.png" />
    <link rel="canonical" href={Astro.url.href} />
    <title>{title} | Fractal IT</title>
    <meta property="og:title" content={`${title} | Fractal IT`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <ClientRouter />

    <script is:inline>
        (function() {
            try {
                if (history.scrollRestoration) {
                    history.scrollRestoration = 'manual';
                }
                var override = localStorage.getItem('lang');
                var isEn = window.location.pathname.startsWith('/en');
                var path = window.location.pathname;
                if (!isEn && override === 'en') {
                    window.location.replace('/en' + path + window.location.search + window.location.hash);
                } else if (isEn && override === 'he') {
                    var newPath = path.replace(/^\/en/, '');
                    window.location.replace((newPath || '/') + window.location.search + window.location.hash);
                }
            } catch (e) {}
        })();
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style is:global>
        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(15px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .animate-in { animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .animate-fade-up {
            opacity: 0;
            animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            animation-delay: var(--delay, 0ms);
        }
        
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, .font-headline { font-family: 'Space Grotesk', sans-serif; }
        .bento-card { background-color: #ffffff; border-radius: 1.5rem; transition: all 0.3s ease; }
        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal-on-scroll.is-visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body class="bg-surface text-on-surface selection:bg-primary-fixed selection:text-on-primary-fixed flex flex-col min-h-screen">
    <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center px-4 md:px-8 py-2 md:py-3 transition-all duration-300 bg-white/70 dark:bg-emerald-950/70 backdrop-blur-xl rounded-[2rem] mt-3 mx-3 md:mx-auto max-w-6xl shadow-[0_20px_40px_rgba(0,104,87,0.06)]">
        <div class="flex items-center relative z-10 transition-transform hover:scale-105 active:scale-95 duration-300">
            <a href="/" class="group flex items-center gap-1.5 sm:gap-2 md:gap-3 no-underline outline-none">
                <!-- User's Custom Uploaded Logo Mark -->
                <img id="nav-logo" src="/logo-icon.png" alt="Fractal Logo Icon" width="64" height="64" class="w-12 h-12 sm:w-16 sm:h-16 md:w-20 md:h-20 lg:w-28 lg:h-28 object-contain shrink-0 drop-shadow-xl -ml-2 -my-2 md:-my-3 lg:-ml-4 lg:-my-6 transition-all duration-300" />

                <div class="flex flex-col justify-center items-start shrink-0" dir="ltr">
                    <!-- Top Row: Fractal ◆ פרקטל -->
                    <div class="flex items-center gap-1 sm:gap-1.5 md:gap-2">
                        <span class="text-[1.15rem] sm:text-[1.4rem] md:text-[1.6rem] lg:text-[1.8rem] font-bold tracking-tight leading-none text-primary font-headline">Fractal</span>
                        <span class="text-secondary/70 text-[0.6rem] sm:text-sm md:text-base leading-none translate-y-[1px]">◆</span>
                        <span class="text-[1.15rem] sm:text-[1.4rem] md:text-[1.6rem] lg:text-[1.8rem] font-bold tracking-tight leading-none text-primary font-headline">פרקטל</span>
                    </div>
                    
                    <!-- Subtitle -->
                    <div class="w-full flex justify-center gap-1.5 sm:gap-2 items-center text-[0.55rem] sm:text-[0.65rem] md:text-[0.7rem] lg:text-[0.8rem] font-bold text-slate-600/90 leading-none mt-1 font-headline tracking-widest">
                        <span>BUSINESS-DRIVEN</span>
                        <span>IT</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="hidden lg:flex flex-1 items-center justify-center pt-1 transition-all">
            <!-- Centered Navigation Links -->
            <div class="flex items-center justify-center w-full gap-6 xl:gap-10">
                <a href="/en/" class="whitespace-nowrap shrink-0 text-on-surface-variant font-medium hover:text-primary transition-colors text-[15px] tracking-wide relative group">Home<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span></a>
                <a href="/en/about" class="whitespace-nowrap shrink-0 text-on-surface-variant font-medium hover:text-primary transition-colors text-[15px] tracking-wide relative group">About Us<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span></a>
                <a href="/en/services" class="whitespace-nowrap shrink-0 text-on-surface-variant font-medium hover:text-primary transition-colors text-[15px] tracking-wide relative group">Our Services<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span></a>
                <a href="/en/customers" class="whitespace-nowrap shrink-0 text-on-surface-variant font-medium hover:text-primary transition-colors text-[15px] tracking-wide relative group">Our Customers<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary transition-all group-hover:w-full"></span></a>
            </div>
        </div>

        <div class="flex items-center gap-2 sm:gap-4 relative z-10 shrink-0">
            <!-- Language Switcher (Desktop) -->
            <a href={hePath} onclick="localStorage.setItem('lang', 'he');" class="hidden lg:flex text-on-surface-variant hover:text-primary transition-colors text-sm font-bold tracking-wide items-center font-headline uppercase" dir="rtl">HE</a>
            
            <div class="hidden lg:block h-5 w-px bg-outline-variant/30"></div>

            <!-- Contact Icons (Desktop & Tablet) -->
            <div class="hidden md:flex items-center gap-2">
                <a href="tel:03-6168890" class="flex items-center justify-center w-10 h-10 rounded-full bg-surface-variant/80 text-on-surface-variant hover:bg-primary hover:text-white transition-all hover:scale-105 active:scale-95" aria-label="Call Us">
                    <span class="material-symbols-outlined text-[20px]">call</span>
                </a>
                <a href="#" onclick="window.location.href='mailto:Office@fractal.co.il'; return false;" class="flex items-center justify-center w-10 h-10 rounded-full bg-surface-variant/80 text-on-surface-variant hover:bg-primary hover:text-white transition-all hover:scale-105 active:scale-95" aria-label="Email Us">
                    <span class="material-symbols-outlined text-[20px]">mail</span>
                </a>
            </div>

            <div class="hidden md:block h-5 w-px bg-outline-variant/30"></div>

            <!-- Tech Support Button (Desktop Only) -->
            <a href="https://f2002.net/" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex px-4 py-2 sm:px-6 sm:py-2.5 bg-gradient-to-br from-primary to-primary-container text-white rounded-full text-xs sm:text-sm font-semibold hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20 whitespace-nowrap">Tech Support</a>
            
            <!-- Mobile Menu Toggle -->
            <button id="mobile-btn-en" class="lg:hidden flex items-center justify-center p-2 rounded-full bg-surface-variant/80 text-on-surface hover:bg-primary hover:text-white transition-all" aria-label="Toggle Menu">
                <span class="material-symbols-outlined" id="mobile-icon-en">menu</span>
            </button>
        </div>
    </nav>
    
    <!-- Mobile Full-Screen Overlay -->
    <div id="mobile-nav-en" class="fixed inset-0 z-[45] bg-surface/95 backdrop-blur-3xl opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden flex flex-col pt-32 px-6 overscroll-none">
        <div class="flex flex-col gap-2">
            <!-- Language Switcher (Mobile) - Top Right (justify-end in LTR) -->
            <div class="flex justify-end px-6 mb-2">
                <a href={hePath} onclick="localStorage.setItem('lang', 'he');" class="text-on-surface-variant hover:text-primary transition-colors text-lg font-bold tracking-wide font-headline uppercase" dir="rtl">HE</a>
            </div>

            <a href="/en/" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group">
                Home <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_right</span>
            </a>
            <a href="/en/about" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group">
                About Us <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_right</span>
            </a>
            <a href="/en/services" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group">
                Our Services <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_right</span>
            </a>
            <a href="/en/customers" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group">
                Our Customers <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_right</span>
            </a>
            <a href="/en/contact" class="text-xl text-slate-700 font-medium py-4 px-6 rounded-2xl hover:bg-primary/5 hover:text-primary transition-all flex justify-between items-center group" onclick="document.getElementById('mobile-btn-en').click()">
                Contact Us <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-primary">chevron_right</span>
            </a>
            
            <div class="mt-8 px-6">
                <!-- Tech Support Button (Mobile Menu) -->
                <a href="https://f2002.net/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full py-4 bg-gradient-to-br from-primary to-primary-container text-white font-bold rounded-xl shadow-lg shadow-primary/20 active:scale-95 transition-all text-lg">
                    <span class="material-symbols-outlined text-xl">support_agent</span>
                    Tech Support
                </a>
            </div>
        </div>
    </div>

    <script is:inline>
        document.addEventListener('astro:page-load', () => {
            const btn = document.getElementById('mobile-btn-en');
            const nav = document.getElementById('mobile-nav-en');
            const icon = document.getElementById('mobile-icon-en');
            const links = nav ? nav.querySelectorAll('a') : [];
            let menuOpen = false;

            if(btn && nav && icon) {
                const toggleMenu = () => {
                    menuOpen = !menuOpen;
                    if(menuOpen) {
                        nav.classList.remove('opacity-0', 'pointer-events-none');
                        nav.classList.add('opacity-100', 'pointer-events-auto');
                        icon.textContent = 'close';
                        document.body.style.overflow = 'hidden';
                    } else {
                        nav.classList.add('opacity-0', 'pointer-events-none');
                        nav.classList.remove('opacity-100', 'pointer-events-auto');
                        icon.textContent = 'menu';
                        document.body.style.overflow = '';
                    }
                };

                // Clear previous listeners (robustness)
                const newBtn = btn.cloneNode(true);
                if (btn.parentNode) btn.parentNode.replaceChild(newBtn, btn);
                newBtn.addEventListener('click', toggleMenu);
                
                links.forEach(link => {
                    link.addEventListener('click', () => {
                        if (menuOpen) toggleMenu();
                    });
                });
            }

            // Phase 3: Dynamic Header
            const mainNav = document.getElementById('main-nav');
            const navLogo = document.getElementById('nav-logo');
            const checkScroll = () => {
                if (window.scrollY > 50) {
                    mainNav?.classList.add('bg-white/90', 'shadow-md', 'py-1');
                    mainNav?.classList.remove('bg-white/70', 'py-2', 'md:py-3', 'shadow-[0_20px_40px_rgba(0,104,87,0.06)]');
                    navLogo?.classList.add('scale-75'); 
                } else {
                    mainNav?.classList.add('bg-white/70', 'py-2', 'md:py-3', 'shadow-[0_20px_40px_rgba(0,104,87,0.06)]');
                    mainNav?.classList.remove('bg-white/90', 'shadow-md', 'py-1');
                    navLogo?.classList.remove('scale-75');
                }
            };
            window.addEventListener('scroll', checkScroll);
            checkScroll(); // Init on load in case of mid-page refresh

            // Phase 2: Scroll Reveal Animations
            const observerOptions = { root: null, rootMargin: '0px', threshold: 0.05 };
            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);
            
            document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));

            // Safety fallback: if anything remained hidden, just show it after 2 seconds
            setTimeout(() => {
                document.querySelectorAll('.reveal-on-scroll:not(.is-visible)').forEach(el => {
                    el.classList.add('is-visible');
                    observer.unobserve(el);
                });
            }, 2000);
        });
    </script>

    <main class="flex-grow pt-24 relative z-0">
        <slot />
    </main>

    <Footer lang="en" />
    <CookieBanner lang="en" />
    <ScrollToTop />

    <!-- Future Analytics Placeholder (Amendment 13 Privacy by Design) -->
    <script is:inline>
        function loadAnalytics() {
            // TODO: Inject actual Google Analytics or Meta Pixel tags here
            console.log("Analytics trackers allowed (consent granted).");
        }
        
        if (localStorage.getItem('cookie-consent') === 'granted') {
            loadAnalytics();
        } else {
            window.addEventListener('cookie-consent-granted', loadAnalytics);
        }
    </script>

    <!-- Open Source Accessibility Widget -->
    <script>
        import { Accessibility } from 'accessibility';

        window.addEventListener('load', function() {
            new Accessibility({
                labels: {
                    menuTitle: 'Accessibility Options',
                },
                icon: {
                    position: {
                        bottom: { size: 30, units: 'px' },
                        left: { size: 30, units: 'px' },
                        type: 'fixed'
                    }
                }
            });
        }, false);
    </script>
</body>
</html>
