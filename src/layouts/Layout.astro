---
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import Navbar from '../components/Navbar.astro';
import AnalyticsTracking from '../components/AnalyticsTracking.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';

export interface Props {
	title: string;
	description?: string;
    lang?: 'en' | 'he';
}

const { 
    title, 
    lang = 'en',
    description = lang === 'he' 
        ? "פרקטל מתמחה במתן פתרונות מחשוב מלאים, שירות ותמיכה טכנית מתקדמת ללקוחות עסקיים ותעשייתיים השואפים למצוינות." 
        : "Fractal specializes in providing IT consulting and support solutions to business and industrial customers who expect excellence." 
} = Astro.props;

const isHe = lang === 'he';
const pathname = Astro.url.pathname;
const altPath = isHe 
    ? '/en' + (pathname === '/' ? '' : pathname)
    : pathname.replace(/^\/en/, '') || '/';
const ogImageUrl = new URL('/og-image.jpg', Astro.url).href;

import enLocales from '../locales/en.json';
import heLocales from '../locales/he.json';

const t = isHe ? heLocales.Layout : enLocales.Layout;
---
<!doctype html>
<html lang={lang} dir={isHe ? "rtl" : "ltr"} class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/logo-icon.png" />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | {t.siteTitle}</title>
    <meta property="og:title" content={`${title} | ${t.siteTitle}`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={isHe ? "he_IL" : "en_US"} />
    <meta property="og:locale:alternate" content={isHe ? "en_US" : "he_IL"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <ClientRouter />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    {isHe ? (
        <>
            <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;600;800;900&display=swap" />
            <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;600;800;900&display=swap" rel="stylesheet">
        </>
    ) : (
        <>
            <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" />
            <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
        </>
    )}
    
    <style is:global define:vars={{ lang }}>
        @tailwind base;
        @tailwind components;
        @tailwind utilities;

        /* Secure base font-size to prevent accessibility plugin from shrinking the layout */
        html {
            font-size: var(--access-base-font-size, 16px) !important;
        }
        
        /* Enforce line-height and spacing overrides strictly across all scoped tailwind utilities when active */
        html.access-line-height-active, html.access-line-height-active * {
            line-height: var(--access-line-height) !important;
        }
        html.access-spacing-active, html.access-spacing-active * {
            letter-spacing: var(--access-letter-spacing) !important;
            word-spacing: var(--access-word-spacing) !important;
        }

        /* Define core variables if not already defined entirely by Tailwind */
        :root {
            --color-primary: 0, 104, 116;
            --color-on-primary: 255, 255, 255;
            --color-primary-container: 151, 240, 255;
            --color-on-primary-container: 0, 31, 36;
            --color-secondary: 74, 98, 103;
            --color-surface: 244, 250, 250;
            --color-on-surface: 22, 29, 29;
            --color-outline: 111, 121, 122;
        }

        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(15px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .animate-in { animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .animate-fade-up {
            opacity: 0;
            animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            animation-delay: var(--delay, 0ms);
        }

        @keyframes shimmerTextLTR {
            0% { background-position: 200% center; }
            100% { background-position: -200% center; }
        }
        @keyframes shimmerTextRTL {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }

        .animate-shimmer-text {
            background: linear-gradient(
                90deg, 
                rgb(var(--color-primary)) 20%, 
                rgb(180, 255, 255) 50%, 
                rgb(var(--color-primary)) 80%
            );
            background-size: 200% auto;
            color: transparent;
            -webkit-background-clip: text;
            background-clip: text;
        }
        html[lang="en"] .animate-shimmer-text {
            animation: shimmerTextLTR 5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        }
        html[lang="he"] .animate-shimmer-text {
            animation: shimmerTextRTL 5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        }
        

        
        html[lang="he"] body { 
            font-family: 'Heebo', sans-serif;
            background-color: rgb(var(--color-surface));
            color: rgb(var(--color-on-surface));
        }
        html[lang="en"] body { 
            font-family: 'Inter', sans-serif;
            background-color: transparent;
            color: inherit;
        }
        html[lang="he"] h1, html[lang="he"] h2, html[lang="he"] h3, html[lang="he"] .font-headline { 
            font-family: 'Heebo', sans-serif; 
        }
        html[lang="en"] h1, html[lang="en"] h2, html[lang="en"] h3, html[lang="en"] .font-headline { 
            font-family: 'Space Grotesk', sans-serif; 
        }

        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal-on-scroll.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Marquee Infinite Scrolling Animations */
        @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        @keyframes marquee-rtl { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }
        @keyframes marquee-up { 0% { transform: translateY(0); } 100% { transform: translateY(-50%); } }
        @keyframes marquee-down { 0% { transform: translateY(-50%); } 100% { transform: translateY(0); } }
        
        .animate-marquee { animation: marquee 35s linear infinite; width: max-content; }
        .animate-marquee-rtl { animation: marquee-rtl 35s linear infinite; width: max-content; }
        .animate-marquee-up { animation: marquee-up 25s linear infinite; height: max-content; }
        .animate-marquee-down { animation: marquee-down 25s linear infinite; height: max-content; }
        
        /* Hardware acceleration for ultra-smooth scrolling */
        .animate-marquee > div, .animate-marquee-rtl > div,
        .animate-marquee-up > div, .animate-marquee-down > div {
            transform: translateZ(0);
            will-change: transform;
        }

        /* Accessibility Widget Overrides */
        html[lang="he"] .accessibility-menu { 
            direction: rtl; 
            text-align: right; 
        }
        html[lang="en"] .accessibility-menu { 
            direction: ltr; 
            text-align: left; 
        }
    </style>
</head>
<body class="bg-surface text-on-surface selection:bg-primary-fixed selection:text-on-primary-fixed flex flex-col min-h-screen">
    <Navbar lang={lang} />

    <main class="flex-grow w-full pb-16 pt-24 relative z-0">
        <slot />
    </main>

    <Footer lang={lang} />
    <CookieBanner lang={lang} />
    <ScrollToTop />

    <AnalyticsTracking />
    <AccessibilityWidget />
</body>
</html>
